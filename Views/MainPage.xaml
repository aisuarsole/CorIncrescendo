<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CorIncrescendo.ViewModels"
             x:Class="CorIncrescendo.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title=""
             BackgroundColor="{StaticResource IncWhite}">

    <Shell.TitleView>
        <Image Source="logo_retallat.png"
               HeightRequest="36"
               Aspect="AspectFit"
               HorizontalOptions="Start"
               Margin="8,0,0,0" />
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*,Auto" Padding="24">

        <!-- Benvinguda -->
        <VerticalStackLayout Grid.Row="0" Margin="0,16,0,32">
            <Label Text="{Binding Salutacio}"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{StaticResource IncBlack}" />
            <Label Text="Escull una opció"
                   FontSize="15"
                   TextColor="Gray" />
        </VerticalStackLayout>

        <!-- Icones de mòduls -->
        <FlexLayout Grid.Row="1"
                    Wrap="Wrap"
                    JustifyContent="Start"
                    AlignItems="Start"
                    Direction="Row">

            <!-- Mòdul Economia -->
            <Border Margin="8"
                    WidthRequest="140"
                    HeightRequest="140"
                    BackgroundColor="{StaticResource IncBlack}"
                    StrokeShape="RoundRectangle 16">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding AnarEconomiaCommand}" />
                </Border.GestureRecognizers>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="10">
                    <Label Text="💰"
                           FontSize="42"
                           HorizontalOptions="Center" />
                    <Label Text="Economia"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{StaticResource IncWhite}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Aquí podràs afegir més mòduls en el futur -->

        </FlexLayout>

        <!-- Botó tancar sessió -->
        <Button Grid.Row="2"
                Text="Tancar sessió"
                Command="{Binding LogoutCommand}"
                BackgroundColor="Transparent"
                TextColor="Gray"
                FontSize="14"
                Margin="0,0,0,16" />
    </Grid>
</ContentPage>