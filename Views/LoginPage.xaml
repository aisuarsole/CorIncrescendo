<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CorIncrescendo.ViewModels"
             x:Class="CorIncrescendo.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource IncWhite}">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="0"
                             VerticalOptions="Center">

            <!-- Logo -->
            <Image Source="logo_increscendo.png"
                   HeightRequest="120"
                   Aspect="AspectFit"
                   Margin="0,40,0,8" />

            <Label Text="cor de cambra"
                   FontFamily="OpenSansRegular"
                   FontSize="14"
                   TextColor="{StaticResource IncBlack}"
                   HorizontalOptions="Center"
                   CharacterSpacing="3"
                   Margin="0,0,0,48" />

            <!-- Formulari -->
            <Label Text="Correu electrònic"
                   FontSize="13"
                   TextColor="{StaticResource IncBlack}"
                   Margin="0,0,0,6" />
            <Entry Placeholder="correu@exemple.com"
                   Text="{Binding Email}"
                   Keyboard="Email"
                   BackgroundColor="{StaticResource IncGray}"
                   TextColor="{StaticResource IncBlack}"
                   PlaceholderColor="Gray"
                   HeightRequest="48"
                   Margin="0,0,0,20" />

            <Label Text="Contrasenya"
                   FontSize="13"
                   TextColor="{StaticResource IncBlack}"
                   Margin="0,0,0,6" />
            <Entry Placeholder="••••••••"
                   Text="{Binding Password}"
                   IsPassword="True"
                   BackgroundColor="{StaticResource IncGray}"
                   TextColor="{StaticResource IncBlack}"
                   PlaceholderColor="Gray"
                   HeightRequest="48"
                   Margin="0,0,0,8" />

            <!-- Nom (solo visible en modo registro) -->
            <Label Text="Nom"
                   FontSize="13"
                   TextColor="{StaticResource IncBlack}"
                   IsVisible="{Binding MostrarCampsRegistre}"
                   Margin="0,0,0,6" />
            <Entry Placeholder="El teu nom"
                   Text="{Binding Nom}"
                   BackgroundColor="{StaticResource IncGray}"
                   TextColor="{StaticResource IncBlack}"
                   PlaceholderColor="Gray"
                   HeightRequest="48"
                   IsVisible="{Binding MostrarCampsRegistre}"
                   Margin="0,0,0,20" />

            <Label Text="Cognoms"
                   FontSize="13"
                   TextColor="{StaticResource IncBlack}"
                   IsVisible="{Binding MostrarCampsRegistre}"
                   Margin="0,0,0,6" />
            <Entry Placeholder="Els teus cognoms"
                   Text="{Binding Cognoms}"
                   BackgroundColor="{StaticResource IncGray}"
                   TextColor="{StaticResource IncBlack}"
                   PlaceholderColor="Gray"
                   HeightRequest="48"
                   IsVisible="{Binding MostrarCampsRegistre}"
                   Margin="0,0,0,20" />

            <!-- Error -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource IncRed}"
                   FontSize="13"
                   IsVisible="{Binding HasError}"
                   Margin="0,0,0,16" />

            <!-- Botó Entrar -->
            <Button Text="ENTRAR"
                    Command="{Binding LoginCommand}"
                    BackgroundColor="{StaticResource IncBlack}"
                    TextColor="{StaticResource IncWhite}"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    CornerRadius="8"
                    Margin="0,8,0,0" />

            <BoxView HeightRequest="1"
                     BackgroundColor="LightGray"
                     Margin="0,32,0,32" />

            <!-- Botó Registrar-me: primer mostra camps, després envia -->
            <Button Text="REGISTRAR-ME"
                    Command="{Binding MostrarCampsRegistre, 
                              Converter={StaticResource BoolToColorConverter}}"
                    BackgroundColor="{StaticResource IncRed}"
                    TextColor="{StaticResource IncWhite}"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    CornerRadius="8">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                     Binding="{Binding MostrarCampsRegistre}"
                     Value="False">
                        <Setter Property="Command" Value="{Binding MostrarRegistreCommand}" />
                        <Setter Property="Text" Value="REGISTRAR-ME" />
                    </DataTrigger>
                    <DataTrigger TargetType="Button"
                     Binding="{Binding MostrarCampsRegistre}"
                     Value="True">
                        <Setter Property="Command" Value="{Binding RegistrarCommand}" />
                        <Setter Property="Text" Value="CREAR COMPTE" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource IncRed}"
                               Margin="0,16,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>