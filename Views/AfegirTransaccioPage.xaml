<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CorIncrescendo.ViewModels"
             x:Class="CorIncrescendo.Views.AfegirTransaccioPage"
             x:DataType="vm:AfegirTransaccioViewModel"
             Title="Nova transacció"
             BackgroundColor="{StaticResource IncWhite}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <!-- Tipus -->
            <Label Text="Tipus" FontSize="13" TextColor="Gray" />
            <HorizontalStackLayout Spacing="12">
                <Button Text="💰 Ingrés"
                        Command="{Binding SeleccionarTipusCommand}"
                        CommandParameter="ingres"
                        BackgroundColor="{Binding EsIngres, Converter={StaticResource BoolToColorConverter}}"
                        TextColor="{StaticResource IncWhite}"
                        CornerRadius="8"
                        HeightRequest="44" />
                <Button Text="💸 Gasto"
                        Command="{Binding SeleccionarTipusCommand}"
                        CommandParameter="gasto"
                        BackgroundColor="{Binding EsGasto, Converter={StaticResource BoolToColorConverter}}"
                        TextColor="{StaticResource IncWhite}"
                        CornerRadius="8"
                        HeightRequest="44" />
            </HorizontalStackLayout>

            <!-- Import -->
            <Label Text="Import (€)" FontSize="13" TextColor="Gray" />
            <Entry Text="{Binding Import}"
                   Keyboard="Numeric"
                   Placeholder="0.00"
                   BackgroundColor="{StaticResource IncGray}"
                   HeightRequest="48"
                   TextColor="{StaticResource IncBlack}" />

            <!-- Descripció -->
            <Label Text="Descripció" FontSize="13" TextColor="Gray" />
            <Entry Text="{Binding Descripcio}"
                   Placeholder="Descripció de la transacció"
                   BackgroundColor="{StaticResource IncGray}"
                   HeightRequest="48"
                   TextColor="{StaticResource IncBlack}" />

            <!-- Categoria -->
            <Label Text="Categoria" FontSize="13" TextColor="Gray" />
            <Picker ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding Categoria}"
                    BackgroundColor="{StaticResource IncGray}"
                    TextColor="{StaticResource IncBlack}"
                    HeightRequest="48" />

            <!-- Data -->
            <Label Text="Data" FontSize="13" TextColor="Gray" />
            <DatePicker Date="{Binding Data}"
                        Format="dd/MM/yyyy"
                        TextColor="{StaticResource IncBlack}"
                        BackgroundColor="{StaticResource IncGray}"
                        HeightRequest="48" />

            <!-- Error -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource IncRed}"
                   IsVisible="{Binding HasError}"
                   FontSize="13" />

            <!-- Botons -->
            <Button Text="GUARDAR"
                    Command="{Binding GuardarCommand}"
                    BackgroundColor="{StaticResource IncBlack}"
                    TextColor="{StaticResource IncWhite}"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    CornerRadius="8"
                    Margin="0,16,0,0" />

            <Button Text="Cancel·lar"
                    Command="{Binding CancellarCommand}"
                    BackgroundColor="Transparent"
                    TextColor="Gray"
                    HeightRequest="44" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>